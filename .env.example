# .env 로 복사한 뒤 값을 입력하세요.
# Gemini (Google AI Studio) API Key
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Netlify: Site settings → Environment variables 에 GEMINI_API_KEY 등을 넣고 재배포하세요.
# (VITE_ 접두어 없음 — Function 전용, 브라우저에 노출되지 않습니다.)

# Netlify 배포 시 Functions 실행 시간이 짧으면(플랜/설정) AI 요청이 타임아웃할 수 있습니다.
# 기본: NETLIFY=true 이면 server/gemini-chat-core.mjs 가 출력·refine·폴백을 줄입니다.
# 끄려면(더 긴 답·refine 허용, 타임아웃 위험 증가): GEMINI_NETLIFY_FAST=0
# GEMINI_NETLIFY_FAST=1 일 때 refine을 다시 켜려면: GEMINI_ENABLE_REFINE=1
# GEMINI_MAX_OUTPUT_TOKENS=2048 처럼 512~8192 숫자로 출력 상한 직접 지정 가능

# 보고서·SWOT·채팅 공통 (pro 과부하·타임아웃 회피): flash
GEMINI_MODEL=gemini-2.5-flash

# 채팅 전용(비우면 GEMINI_MODEL 과 동일)
GEMINI_CHAT_MODEL=gemini-2.5-flash

# 채팅 과부하 시 순서대로 다른 flash 모델 시도
# flash-lite 등 구형 모델은 신규 API 키에서 차단됨 — 사용하지 마세요
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash

# 로컬: Gemini API 최대 대기(ms). npm run dev 재시작 후 적용
# GEMINI_FETCH_TIMEOUT_MS=120000

# 관리자 모드(로컬 게이트): 서버 로그인 실패 시에만 사용. 빌드에 포함되므로 강한 값으로 변경하세요.
# VITE_TEACHER_USERNAME=admin
# VITE_TEACHER_PASSWORD=your-secure-password

# 로컬: `npm run dev` 만 실행해도 제출 sync-server 가 자동으로 뜹니다(.env.development 참고).
# Netlify와 완전 동일하게 쓰려면: npm run dev:netlify
# (처음 실행 시 npx 가 Netlify CLI 를 받습니다. 전역 설치를 원하면: npm i -g netlify-cli 후 스크립트에서 npx 대신 netlify 사용)
# 일반 `npm run dev` 만 쓰면 Vite만 떠서 /api/submissions 가 없음 → 기기별 로컬 저장만 됨
# 브라우저는 안내에 나온 대로 보통 http://localhost:8888 — Vite(5173)로 프록시됩니다.
# 처음이면: npx netlify login && npx netlify link (배포 사이트와 연결, Blobs/환경 변수 공유)
#
# Netlify 배포: netlify.toml 의 [build.environment] 로 VITE_SUBMISSIONS_SAME_ORIGIN 이 켜지면
# 제출 API는 같은 사이트의 /.netlify/functions/submissions-sync (Blobs)로 붙습니다.
# Site settings → Environment variables 에 아래를 넣는 것을 권장합니다(비어 있으면 누구나 API 호출 가능).
#
# Functions 전용(브라우저에 노출 안 됨):
# SUBMISSIONS_STUDENT_TOKEN=
# SUBMISSIONS_TEACHER_PASSWORD=
# (선택) SUBMISSIONS_TEACHERS_JSON=...  # server/README.md 참고
#
# 빌드에 포함(학생 제출용 — 반/수업 공유용 비밀):
# VITE_SUBMISSIONS_STUDENT_TOKEN=  ← SUBMISSIONS_STUDENT_TOKEN 과 동일 값
#
# 로컬에서만 외부 sync 서버를 쓰려면 .env 에:
# VITE_SUBMISSIONS_API_URL=http://127.0.0.1:8787
# 그리고 netlify.toml 의 VITE_SUBMISSIONS_SAME_ORIGIN 을 제거하거나 false 로 두세요.
#
# (호환) 단일 토큰: VITE_SUBMISSIONS_API_TOKEN= + Functions 에 SUBMISSIONS_API_TOKEN=
#
# (권장) 교사 로그인: Functions 에 SUBMISSIONS_TEACHER_PASSWORD(또는 SUBMISSIONS_TEACHERS_JSON).
# 프런트는 관리자 화면에서 비밀번호 입력 시 세션 토큰을 받아 sessionStorage에 저장합니다.
