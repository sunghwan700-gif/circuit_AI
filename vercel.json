{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "build": {
    "env": {
      "VITE_SUBMISSIONS_SAME_ORIGIN": "true",
      "VITE_VERCEL_DEPLOY": "true",
      "VITE_GEMINI_CHAT_MODEL": "gemini-2.5-pro",
      "VITE_AI_CHAT_BACKGROUND": "false"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/ping.js": {
      "runtime": "nodejs"
    },
    "api/submissions/**/*.js": {
      "runtime": "nodejs",
      "maxDuration": 30,
      "includeFiles": "api/_bundled/**"
    },
    "api/auth/**/*.js": {
      "runtime": "nodejs",
      "maxDuration": 30,
      "includeFiles": "api/_bundled/**"
    },
    "api/openai/**/*.js": {
      "runtime": "nodejs",
      "maxDuration": 60,
      "includeFiles": "api/_bundled/**"
    }
  }
}
