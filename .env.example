# .env 로 복사한 뒤 값을 입력하세요.
# Gemini (Google AI Studio) API Key
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Vercel: Project → Settings → Environment Variables + Storage(KV) 연결
# (VITE_ 접두어 없음 — Function 전용, 브라우저에 노출되지 않습니다.)

# 서버리스에서 출력·이미지를 줄이려면(기본 꺼짐): GEMINI_SERVERLESS_COMPACT=1
# 동기 Pro를 짧게(23초·토큰 축소) 쓰려면: GEMINI_SYNC_PRO_TIGHT=1
# GEMINI_ENABLE_REFINE=1 — compact 모드에서 refine 허용
# GEMINI_MAX_OUTPUT_TOKENS=2048 처럼 512~8192 숫자로 출력 상한 직접 지정 가능

# Pro: 정밀 분석 (Vercel 스트리밍)
GEMINI_MODEL=gemini-2.5-pro
GEMINI_CHAT_MODEL=gemini-2.5-pro
VITE_GEMINI_CHAT_MODEL=gemini-2.5-pro
VITE_AI_CHAT_BACKGROUND=false
# GEMINI_BG_FETCH_TIMEOUT_MS=180000

# Pro 실패·과부하 시 자동 전환
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash

# 로컬: Gemini API 최대 대기(ms). npm run dev 재시작 후 적용
# GEMINI_FETCH_TIMEOUT_MS=120000

# 관리자 모드(로컬 게이트): 서버 로그인 실패 시에만 사용. 빌드에 포함되므로 강한 값으로 변경하세요.
# VITE_TEACHER_USERNAME=admin
# VITE_TEACHER_PASSWORD=your-secure-password

# 로컬: `npm run dev` — Vite 미들웨어가 /api/openai/chat 처리, 제출은 server/data/kv JSON
# 배포와 동일: npm run dev:vercel

# Vercel 빌드(vercel.json): VITE_SUBMISSIONS_SAME_ORIGIN=true → 같은 출처 /api/submissions
#
# Functions 전용(브라우저에 노출 안 됨):
# SUBMISSIONS_STUDENT_TOKEN=
# SUBMISSIONS_TEACHER_PASSWORD=
# (선택) SUBMISSIONS_TEACHERS_JSON=...  # server/README.md 참고
#
# 빌드에 포함(학생 제출용):
# VITE_SUBMISSIONS_STUDENT_TOKEN=  ← SUBMISSIONS_STUDENT_TOKEN 과 동일 값
#
# 로컬에서만 외부 sync 서버를 쓰려면:
# VITE_SUBMISSIONS_API_URL=http://127.0.0.1:8787
#
# (호환) 단일 토큰: VITE_SUBMISSIONS_API_TOKEN= + SUBMISSIONS_API_TOKEN=
#
# 교사 로그인: SUBMISSIONS_TEACHER_PASSWORD(또는 SUBMISSIONS_TEACHERS_JSON).
# 프런트는 관리자 화면에서 비밀번호 입력 시 세션 토큰을 받아 sessionStorage에 저장합니다.
